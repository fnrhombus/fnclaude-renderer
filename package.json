{
  "name": "fnclaude-renderer",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Configurable TUI front-end for Claude Code with stream-json driving, toggleable visibility filters, and glow-piped markdown.",
  "license": "MIT",
  "author": "fnrhombus",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fnrhombus/fnclaude-renderer.git"
  },
  "bin": {
    "fnclaude-renderer": "./src/index.tsx"
  },
  "scripts": {
    "dev": "bun run src/index.tsx",
    "build": "bun build --compile --outfile=bin/fnclaude-renderer ./src/index.tsx",
    "typecheck": "tsc --noEmit",
    "check": "biome check .",
    "fmt": "biome format --write .",
    "lint": "biome lint .",
    "test": "bun test"
  },
  "dependencies": {
    "ink": "^5.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/react": "^18.3.0",
    "bun-types": "^1.3.14",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
